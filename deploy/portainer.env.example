DOKSIO_HTTP_PORT=8000
DOKSIO_PUBLIC_BASE_URL=https://doksio.example.test
DOKSIO_OIDC_ENABLED=false
DOKSIO_OIDC_ISSUER_URL=https://auth.example.test/application/o/doksio
DOKSIO_OIDC_CLIENT_ID=
DOKSIO_OIDC_CLIENT_SECRET=
DOKSIO_OIDC_AUTO_CREATE_USERS=true
DOKSIO_OIDC_SCOPE=openid email profile
DOKSIO_OIDC_USERNAME_CLAIM=preferred_username
DOKSIO_OIDC_TENANT_CLAIM=doksio_tenants

DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=doksio.example.test
DJANGO_CSRF_TRUSTED_ORIGINS=https://doksio.example.test
DJANGO_USE_X_FORWARDED_HOST=true
DJANGO_SECURE_PROXY_SSL_HEADER=true
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=104857600
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
POSTGRES_DB=doksio
POSTGRES_USER=doksio
POSTGRES_PASSWORD=change-me-db-password

REDIS_URL=redis://redis:6379/0

S3_ACCESS_KEY_ID=doksio
S3_SECRET_ACCESS_KEY=change-me-minio-secret
S3_STORAGE_BUCKET_NAME=doksio-documents
S3_REGION_NAME=eu-central-1

OCR_LANGUAGE=deu+eng
OCR_AUTO_START_ON_UPLOAD=true
OCR_TESSERACT_TIMEOUT_SECONDS=120
OCR_IMAGE_MAX_EDGE=3000
OCR_IMAGE_MAX_PAGES=25
OCR_IMAGE_ENHANCED_MAX_PAGES=1
SCAN_OPTIMIZATION_BATCH_SIZE=100
SCAN_OPTIMIZATION_STALE_AFTER_SECONDS=120
SCAN_OPTIMIZATION_LEASE_SECONDS=1920
OMP_THREAD_LIMIT=1
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
