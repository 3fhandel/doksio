DJANGO_SETTINGS_MODULE=doksio.project.settings.docker
DJANGO_SECRET_KEY=change-me-in-local-development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DOKSIO_PUBLIC_BASE_URL=http://localhost:8000
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=104857600
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=false
DJANGO_EMAIL_USE_SSL=false
DJANGO_DEFAULT_FROM_EMAIL=Doksio <noreply@localhost>

POSTGRES_DB=doksio
POSTGRES_USER=doksio
POSTGRES_PASSWORD=doksio
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

OCR_LANGUAGE=deu+eng
OCR_AUTO_START_ON_UPLOAD=true
OCR_RUN_INLINE=false
OCR_TESSERACT_TIMEOUT_SECONDS=120
OCR_IMAGE_MAX_EDGE=3000
OCR_IMAGE_MAX_PAGES=25
OCR_IMAGE_ENHANCED_MAX_PAGES=1
OMP_THREAD_LIMIT=1
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=doksio
S3_SECRET_ACCESS_KEY=doksio-secret
S3_STORAGE_BUCKET_NAME=doksio-documents
S3_REGION_NAME=eu-central-1
